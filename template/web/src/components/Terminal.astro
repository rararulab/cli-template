---
interface Props {
  label?: string;
}

const { label = "Terminal" } = Astro.props;
---

<div class="terminal reveal">
  <div class="terminal__bar">
    <span class="terminal__dot"></span>
    <span class="terminal__dot"></span>
    <span class="terminal__dot"></span>
  </div>
  <pre class="terminal__body" aria-label={label}><code><slot /></code></pre>
</div>
